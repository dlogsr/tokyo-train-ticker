# Tokyo Train Ticker configuration
# Copy to .env and fill in values

# ODPT API key (free, register at https://developer.odpt.org/)
# Without this key the app runs in DEMO mode with simulated data
ODPT_API_KEY=

# Default station to show on boot (station ID from the stations list)
# Options: shibuya, shinjuku, tokyo, ikebukuro, ueno, etc.
DEFAULT_STATION=shibuya

# Default mode: station | line
DEFAULT_MODE=station
