[Unit]
Description=Tokyo Train Ticker Backend
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=dlogsr
WorkingDirectory=/home/dlogsr/tokyo-train-ticker/backend
ExecStart=/home/dlogsr/tokyo-train-ticker/venv/bin/uvicorn main:app --host 0.0.0.0 --port 8000
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
